
@model ITIEntities.Category

@{
    Layout = "_Layout";
    ViewData["Title"] = "Delete Category";
}

<style>
    :root {
        --brand: #1A4270;
    }

    h1, h3 {
        color: var(--brand);
        font-weight: 600;
    }

    .card-custom {
        border: 1px solid #e3e6ea;
        border-radius: 10px;
        box-shadow: 0 3px 8px rgba(0,0,0,0.05);
    }

    .card-header {
        background: var(--brand);
        color: white;
        font-weight: 600;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
        text-align: center;
        font-size: 20px;
    }

    .table th {
        width: 40%;
    }

    .btn-brand {
        background: var(--brand);
        color: white;
        border: none;
    }

        .btn-brand:hover {
            background: #16365c;
            color: white;
        }

    .btn-brand-outline {
        background: white;
        color: var(--brand);
        border: 2px solid var(--brand);
    }

        .btn-brand-outline:hover {
            background: var(--brand);
            color: white;
        }

    .form-container {
        max-width: 700px;
        margin: auto;
    }

    .alert-danger {
        border-radius: 10px;
    }

    .badge {
        font-size: 0.9rem;
    }
</style>

<div class="container mt-4">
    <h3 class="mb-3"><i class="bi bi-exclamation-triangle"></i> Are you sure you want to delete this category?</h3>

    <div class="card card-custom">
        <div class="card-header">
            Category Details
        </div>

        <div class="card-body form-container">
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Property</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Category Name</strong></td>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <td><strong>Parent Category</strong></td>
                        <td>@(Model.ParentCategory != null ? Model.ParentCategory.Name : "None")</td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex gap-2">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="CategoryId" />
                    <button type="submit" class="btn btn-brand">
                        <i class="bi bi-trash"></i> Confirm Delete
                    </button>
                </form>

                <a asp-action="Index" class="btn btn-outline-danger">Cancel</a>
            </div>
        </div>
    </div>
</div>
