@using Shopping.ViewModels
@model CategoryVM

@{
    Layout = "_Layout";
}


<style>
    :root {
        --brand: #1A4270;
    }

    .card-custom {
        border: 1px solid #e3e6ea;
        border-radius: 10px;
        box-shadow: 0 3px 8px rgba(0,0,0,0.05);
    }

    .card-header {
        background: var(--brand);
        color: white;
        font-weight: 600;
        text-align: center;
        font-size: 20px;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }

    label {
        font-weight: 500;
        color: var(--brand);
    }

    .form-control {
        border-radius: 6px;
    }

    .btn-brand {
        background: var(--brand);
        color: white;
        border: none;
    }

    .btn-brand:hover {
        background: #16365c;
        color: white;
    }

    .btn-brand-outline {
        background: white;
        color: var(--brand);
        border: 2px solid var(--brand);
    }

    .btn-brand-outline:hover {
        background: var(--brand);
        color: white;
    }

    .form-container {
        max-width: 600px;
        margin: auto;
    }

</style>

<div class="container mt-4">
    <div class="card card-custom">
        <div class="card-header">
            Edit Category
        </div>
        <div class="card-body form-container">
        <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="CategoryId" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <br/>
                <div class="form-group mb-4">
                <label asp-for="ParentCategoryId" class="control-label"></label>
                <select asp-for="ParentCategoryId" class="form-control" asp-items="ViewBag.ParentCategories">
                    <option value="">-- Select Parent Category --</option>
                </select>   
                <span asp-validation-for="ParentCategoryId" class="text-danger"></span>
            </div>
            <br/>
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-brand me-3">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-danger">Cancel</a>
                </div>
        </form>
    </div>
</div>
</div>
<br/>
<div>
    <a asp-action="Index" class="btn btn-brand-outline">Back to List</a>
</div>

