@model List<Shopping.ViewModels.Order_ItemsVM>

@{
    ViewData["Title"] = "My Cart";
    Layout = "nav";

}
<style>
    :root {
        --brand-dark: #1A4270;
        --brand-light: #5cc8f7;
        --white: white;
    }

    .text-brand-dark {
        color: var(--brand-dark);
    }

    .text-brand-light {
        color: var(--brand-light);
    }

    .bg-brand-dark {
        background-color: var(--brand-dark);
        color: white; 
    }

    .table-brand-custom,
    .table-brand-custom th,
    .table-brand-custom td {
        background-color: var(--brand-dark);
        color: white !important;
        border-color: rgba(255,255,255,0.2);
        }
    .btn-brand2 {
        background: var(--brand);
        color: white;
        border: none;
    }

        .btn-brand2:hover {
            background: #16365c;
            color: white;
        }

    .btn-brand2-outline {
        background-color: white;
        color: var(--brand-dark);
        border: 2px solid var(--brand-dark);
    }

        .btn-brand2-outline:hover {
            background-color: var(--brand-dark);
            color: white;
            border-color: var(--brand-dark);
        }
</style>
<h2 class="mb-4 text-brand-dark">🛒 My Cart</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Your cart is empty.
    </div>
}
else
{
    <table class="table table-bordered table-brand-custom">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>

        <tbody class="bg-brand-dark">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>$@item.UnitPrice</td>

                    <td>
                        <form asp-action="Update" method="post" class="d-flex align-items-center">
                            <input type="hidden" name="itemId" value="@item.OrderItemID" />

                            <button type="button" class="btn btn-outline-info text-brand-light  btn-sm"
                                    onclick="decreaseQty(this)">
                                −
                            </button>

                            <input type="number"
                                   name="qty"
                                   value="@item.Quantity"
                                   min="1"
                                   class="form-control text-center mx-2"
                                   style="width:60px"
                                   onchange="this.form.submit()" />

                            <button type="button" class="btn btn-outline-info text-brand-light  btn-sm"
                                    onclick="increaseQty(this)">
                                +
                            </button>
                        </form>
                    </td>

                    <td>$@item.LineTotal</td>

                    <td>
                        <a asp-action="Remove"
                           asp-route-itemId="@item.OrderItemID"
                           class="btn btn-danger btn-sm">
                            Remove
                        </a>
                    </td>

                </tr>
            }
        <tfoot>
            <tr>
                <td colspan="3" class="text-end fw-bold">Cart Total</td>
                <td class="fw-bold">
                    $@Model.Sum(i => i.LineTotal)
                </td>
            </tr>
        </tfoot>

        </tbody>
    </table>
}
<div class="text-end mt-3">
    <a asp-action="Checkout" asp-controller="Order" class="btn btn-brand2-outline">
        Proceed to Checkout 🛒
    </a>
</div>

<script>
    function increaseQty(btn) {
        let input = btn.parentElement.querySelector("input[name='qty']");
        input.value = parseInt(input.value) + 1;
        btn.closest("form").submit();
    }

    function decreaseQty(btn) {
        let input = btn.parentElement.querySelector("input[name='qty']");
        if (input.value > 1) {
            input.value = parseInt(input.value) - 1;
            btn.closest("form").submit();
        }
    }
</script>