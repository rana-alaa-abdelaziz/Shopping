@model ITIEntities.Order
@{
    ViewData["Title"] = "Order Details";
}
<style>
    :root {
        --brand-dark: #1A4270;
        --brand-light: #5cc8f7;
    }

    .text-brand-dark {
        color: var(--brand-dark) !important;
    }

    .detail-card {
        border-radius: 15px;
        background-color: white;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--brand-dark);
        border-bottom: 2px solid var(--brand-light);
        display: inline-block;
        padding-bottom: 5px;
    }

    .btn-outline-brand {
        border: 2px solid var(--brand-dark);
        color: var(--brand-dark);
        font-weight: 600;
        border-radius: 10px;
        transition: 0.3s;
    }

        .btn-outline-brand:hover {
            background-color: var(--brand-dark);
            color: white;
        }

    .table-custom thead {
        background-color: #f8fbff;
        color: var(--brand-dark);
    }

    .product-name {
        color: var(--brand-dark);
        font-weight: 600;
    }
   
</style>
<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="text-muted small text-uppercase fw-bold">Order Receipt</span>
            <h2 class="text-brand-dark fw-bold">Order #@Model.OrderNumber</h2>
        </div>
        <a asp-action="Index" class="btn btn-outline-brand px-4">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to History
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card detail-card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5 class="section-title mb-4">
                        <i class="fa-solid fa-location-dot me-2"></i>Shipping To
                    </h5>
                    @if (Model.Address != null)
                    {
                        <div class="lh-lg">
                            <p class="mb-1 fw-bold fs-5 text-brand-dark">@Model.App_User?.FullName</p>
                            <p class="mb-0 text-secondary">
                                <i class="fa-solid fa-house me-2 small"></i>@Model.Address.Street<br />
                                <i class="fa-solid fa-city me-2 small"></i>@Model.Address.City, @Model.Address.Zip<br />
                                <i class="fa-solid fa-flag me-2 small"></i>@Model.Address.Country
                            </p>
                        </div>
                    }
                    <div class="mt-4 pt-4 border-top">
                        <p class="small text-muted mb-1">Order Placed On</p>
                        <p class="fw-bold text-brand-dark">@Model.OrderDate.ToLongDateString()</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card detail-card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5 class="section-title mb-4">
                        <i class="fa-solid fa-box-archive me-2"></i>Items Purchased
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-custom align-middle">
                            <thead>
                                <tr>
                                    <th class="border-0">Product</th>
                                    <th class="text-center border-0">Qty</th>
                                    <th class="text-end border-0">Unit Price</th>
                                    <th class="text-end border-0">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>
                                            <span class="product-name">@item.Product.Name</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill bg-light text-dark border">@item.Quantity</span>
                                        </td>
                                        <td class="text-end text-secondary">$@item.UnitPrice.ToString("F2")</td>
                                        <td class="text-end fw-bold text-brand-dark">$@( (item.UnitPrice * item.Quantity).ToString("F2") )</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end border-0 pt-4">
                                        <span class="text-muted">Grand Total:</span>
                                    </td>
                                    <td class="text-end border-0 pt-4">
                                        <span class="fw-bold fs-4" style="color: var(--brand-light);">$@Model.TotalAmount.ToString("F2")</span>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>